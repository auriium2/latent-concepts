{
	"extends": "astro/tsconfigs/strict",
	"include": [
		".astro/types.d.ts",
		"**/*",
		"./worker-configuration.d.ts"
	],
	"exclude": [
		"dist"
	],
	"compilerOptions": {
		"strictNullChecks": true,
		"allowJs": true,
		"baseUrl": ".",
		"paths": {
			"@components/*": [
				"src/components/*"
			],
			"@assets/*": [
				"src/assets/*"
			],
			"@config/*": [
				"src/config/*"
			],
			"@layouts/*": [
				"src/layouts/*"
			],
			"@pages/*": [
				"src/pages/*"
			],
			"@styles/*": [
				"src/styles/*"
			]
		},
		"jsx": "react-jsx",
		"jsxImportSource": "react"
	}
}